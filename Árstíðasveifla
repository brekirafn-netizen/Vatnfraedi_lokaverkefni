plt.xticks(range(1,13), ['Jan','Feb','Mar','Apr','Maí','Jún','Júl','Ágú','Sep','Okt','Nóv','Des'])
plt.xlabel("Mánuður")
plt.ylabel("Rennsli (m³/s)")
plt.title("Meðaltalsár rennslis")
