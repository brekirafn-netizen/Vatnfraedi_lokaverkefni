#Úrkoma

precip_df = pd.read_csv("vedur.csv", sep=';')
precip_df['Date'] = pd.to_datetime({'year': precip_df['YYYY'], 'month': precip_df['MM'], 'day': precip_df['DD']})
precip_df['month'] = precip_df['Date'].dt.month


precip_clim = precip_df.groupby('month')['prec_carra'].mean()
print(precip_clim)


plt.figure(figsize=(8,5))
plt.bar(precip_clim.index, precip_clim.values) 
plt.xticks(range(1,13), ['Jan','Feb','Mar','Apr','Maí','Jún','Júl','Ágú','Sep','Okt','Nóv','Des'])
plt.xlabel('Mánuður')
plt.ylabel('Úrkoma (mm)')
plt.title('Meðaldagleg úrkoma')
plt.grid(axis='y') 
plt.tight_layout()
plt.show()
